---
import BaseLayout from "../layouts/BaseLayout.astro";

// Base-aware URLs. On GitHub Pages everything sits under /cfd-website; only
// Astro frontmatter can read import.meta.env.BASE_URL. Hardcoded paths 404.
const base = import.meta.env.BASE_URL;
const b = base.endsWith("/") ? base : base + "/";
const img = (file: string) => b + "images/" + file;
const buildingImg = img("building.jpg");

const tel = "tel:360-568-6017";

// External + social links — verbatim from products.md (Contact & location).
const instagramUrl = "https://www.instagram.com/cfdentistrysnoho/";
const facebookUrl = "https://www.facebook.com/CFDsnohomish/";
const billPayUrl = "https://bestcardteam.com/Payments/?Profile=centennialfamPAY";
const email = "info@cfdentistrysnohomish.com";

// Google Maps link to the verbatim address (same convention as the Home page:
// no map is stated on the source site, so this is a redesign-added convenience
// link, not a quoted fact — the address string itself is verbatim).
const mapsUrl =
  "https://www.google.com/maps/search/?api=1&query=133+Maple+Ave+Snohomish+WA+98290";

// -------------------------------------------------------------------------
// THE PEOPLE — one flat flow, doctors first, everyone in the same format
// (mirrors the source site's own presentation: the hierarchy reads from the
// photos, not from section headings or role labels). Names verbatim from
// products.md (gotcha 11). Roles are woven into bio prose, verbatim titles.
// Bios are REWRITTEN from the about-us evidence into third person: phrasing
// may change, facts may not (voice Rule 10). Photos matched by the
// capture-log filename map, GPS/EXIF stripped.
// Becca has no real photo (source uses the practice logo as a placeholder), so
// she gets a text-only card rather than a substituted face.
// -------------------------------------------------------------------------
const people = [
  // ---- Doctors (pale-green bands). Bios VERBATIM from the original site
  // (brand/_sources/2026-07-22/about-us.md) — owner instruction 2026-07-23:
  // "Do not change that copy. Those are written in the voices of the actual
  // staff." Typos and quirks in the source are preserved ("form Scripps",
  // "hiking the trials", "Medicaid..", Savannah's "in 2016 have been").
  // Paragraph breaks restore the original page's breaks that the scrape
  // flattened (split where sentences run together without a space).
  {
    name: "Dr. Eve Rutherford",
    doctor: true,
    photo: "dr-eve-rutherford.jpg",
    paras: [
      "Dr. Eve Rutherford is a graduate of the University of Washington School of Dentistry and received a Bachelor of Arts with Honors in Biology form Scripps College in Claremont, California. Prior to entering dental school, she worked in the Department of Pathology at the University of Washington studying connective tissue disorders. Dr. Eve was raised in Kalispell, Montana where she graduated from Flathead High School.",
      "I am dedicated to improving the oral health and overall health of my patients. My goal is to prevent oral disease and educate patients about the links between a healthy mouth and a healthy body. I love being a dentist and serving my patients through conscious and mindful care. My dedication to improving oral health in the community extends to work I do outside the office. I have served on the Board of Directors for Washington Dental Service Foundation since 2015. During 2016 I served on a task force with Washington State Health Care Authority that seeks to improve benefits for Adult Dental Medicaid.. I am also active with the ABCD Program (Access to Baby and Child Dentistry), and Affiliate Faculty for the University of Washington Department of Pediatric Dentistry.",
      "I have two active sons who keep me on my toes. We enjoy hiking the trials in Snohomish County and biking on Centennial Trail. My husband and I enjoy golfing and going out for sushi.",
      "On my own time, I love to go running and read books.",
      "Dr. Rutherford practices Mondays, Tuesdays, Wednesdays, and Thursdays.",
    ],
  },
  {
    name: "Dr. Rachel Greene",
    doctor: true,
    photo: "dr-rachel-greene.jpg",
    paras: [
      "Dr. Rachel (Krell) Greene is a graduate of the University of Michigan School of Dentistry and received Bachelor of Arts with Honors in Science, Technology and Society from the University of Puget Sound. Dr. Greene was born and raised in Snohomish and is happy to have returned to her hometown to practice in the community she grew up in. In addition to practicing dentistry, Dr. Greene is a professor at the University of Washington School of Dentistry working as the Clinical Director of Western Washington for the Service Learning Program and as a Clinical Instructor in the student patient clinic.",
      "Dentistry is my passion and I enjoy empowering others to have a healthy mouth. I strive to help all patients have a positive dental experience and feel at ease coming to the dentist. I empathize with those who have dental anxiety and am more than willing to work with you to determine the best way to provide you with comfortable care. As a detail oriented person, my restorative focus is on precision and I strive for excellence in all my work. I look forward to meeting you and finding out how our office can best serve your dental care needs.",
      "Dr. Greene practices on Thursdays and Fridays by appointment.",
    ],
  },
  {
    name: "Dr. Samiksha Gulrajani",
    doctor: true,
    photo: "dr-samiksha-gulrajani.jpg",
    paras: [
      "Originally from Cincinnati, Ohio, she completed her undergraduate studies in Mathematics and Neuroscience at the University of Pittsburgh, graduating with honors. She also earned a minor in Chemistry before completing her Doctor of Dental Medicine (DMD) degree at the University of Pittsburgh School of Dental Medicine. Following her education, Dr. Gulrajani further honed her skills during her residency in Advanced Education in General Dentistry (AEGD), where she treated complex cases both at the University and at a local urgent care clinic. She specializes in providing comprehensive dental care, with a particular focus on patients with special needs.",
      "Outside of her professional work, Dr. Gulrajani enjoys spending time watching for orcas and baking delicious desserts.",
      "Dr. Gulrajani practices on Monday, Tuesday, and Wednesday",
    ],
  },
  // ---- Staff (white bands). Same rule: verbatim first-person bios.
  {
    name: "Brooke",
    photo: "brooke.jpg",
    paras: [
      "I am one of our dental hygienists and have been with the office since 2018. I graduated from Lake Washington in 2014 and bring 10 years of experience.",
      "I love getting to know my patients on a personal level and helping them find what works best for them to keep their oral health the best it can be.",
      "When not in the office, I love to garden and spend time with my husband and kids.",
    ],
  },
  {
    name: "Savannah",
    photo: "savannah.jpg",
    paras: [
      "I am a dedicated dental hygienist and bring my expertise and passion to every patient interaction. I earned my bachelor's degree from Seattle Central in 2016 have been a part of the Centennial team since 2021.",
      "As a native to the Pacific Northwest, I was born and raised in Kirkland. I have a deep commitment to preventative dental care and patient education, ensuring each patient feels informed and cared for during their visit. My approach to dental hygiene is both thorough and compassionate.",
      "When not at the office I enjoy spending quality time with my husband and two children.",
      "I feel so privileged to work alongside such knowledgeable and supportive dentists at Centennial, and look forward to providing exceptional care to the community",
    ],
  },
  {
    name: "Juliana",
    photo: "juliana.jpg",
    paras: [
      "I am very excited to join the Centennial team. Originally from Florida, I received my Bachelor of Science degree in Biology from Nova Southeastern University. I went on to graduate from Indian River State College in 2013 with a degree in Dental Hygiene. Right after graduation, I moved to Washington and now call this beautiful state home. I am incredibly grateful to have found such an amazing dental office with thoughtful, caring, and supportive dentists and staff.",
      "I am passionate about providing gentle personalized care along with patient education to help empower you to make informed decisions about your oral health. I look forward to building relationships with all of you while helping you achieve healthy, beautiful smiles.",
      "Outside of work, I love spending time with my husband and our two kids. When I get a moment to myself, you can find me curled up with a good book or watching a movie or TV show.",
    ],
  },
  {
    name: "Becca",
    photo: null,
    paras: ["Details coming soon!"],
  },
  {
    name: "Amaya",
    photo: "amaya.jpg",
    paras: [
      "I am a dental assistant and graduated the West Coast College of Dental Assisting in 2022.",
      "I bring my advancing skills and knowledge to make every visit go as smoothly as possible. I love to help patients be happy and confident in their smile.",
      "When not at the office I enjoy country music concerts and camping with my boyfriend and dog, Piper.",
    ],
  },
  {
    name: "Jessica",
    photo: "jessica.jpg",
    paras: [
      "I joined Centennial in 2021 with over 15 years of experience.",
      "If you are doing Invisalign with our office, you'll probably see me the most! I really enjoy getting to know all of our patients, especially those I get to see every 6 weeks for their Invisalign check ins.",
      "Originally from San Jose, I moved to Washington in 2018. I love spending time with my family am always looking for good movie recommendations!",
    ],
  },
  {
    name: "Kadi",
    photo: "kadi.jpg",
    paras: [
      "I joined Centennial in 2024 after graduating from West Coast College of Dental Assisting.",
      "My favorite part of each day is the time I get to spend with my patients. I love getting to know people and working with people with anxiety to have the best possible visit. My goal is to make you feel as comfortable as possible.",
      "Outside of the office, I get to enjoy time with close friends and love to get outside!",
    ],
  },
  {
    name: "Yana",
    photo: "yana.jpg",
    paras: [
      "I started with the office in 2024. I come from a medical office and bring my passion for community and patient care.",
      "I love to make our Kids' Days fun for everyone, including the parents. I have so much fun designing letters and flyers for our office and look forward to any time I get to reach out to the community.",
      "When I'm not at the office, I am probably hosting a dinner party or traveling with my husband.",
    ],
  },
  {
    name: "Ciara",
    photo: "ciara.jpg",
    paras: [
      "I joined the team in 2024 and am bringing 6 years of scheduling and insurance billing expertise.",
      "I love when a patient can leave smiling with all the information they need.",
      "I am a native to Washington state and grew up in Lake Stevens. When not in the office, I am probably in another country or at a country music concert.",
    ],
  },
  {
    name: "Kayleen",
    photo: "kayleen.jpg",
    paras: [
      "I joined the team in 2025 and have 8 years of experience building trusting relationships. I come from a background of personal banking which has helped me develop excellent organizational skills and a passion for helping people feel comfortable and taken care of. I love bringing those skills into the office and being one of the first friendly faces our patients interact with.",
      "I enjoy assisting patients with scheduling, answering questions, and helping make each visit as smooth and stress-free as possible.",
      "I am a native to Washington state and grew up in Lake Stevens.  Outside of the office, I enjoy playing board games with my husband and spending time with our dog, Millie.",
    ],
  },
  {
    name: "Molly",
    photo: "molly.jpg",
    paras: [
      "I joined Centennial in 2023 with three years of experience in dental billing. I also hold a Dental Assisting license.",
      "I am very passionate about helping patients get the most out of their insurance benefits. I will work on claims as long as it takes to get as much paid as possible. My favorite phone calls to make are the ones when I get to say that insurance paid more than we thought they would.",
      "I am usually back in my office but love to visit with patients in the lobby or on the phone.",
      "When not in the office, I am outside somewhere in the woods with my favorite dogs Sunny and Dottie, or on a road trip.",
    ],
  },
  {
    name: "Marne",
    photo: "marne.jpg",
    paras: [
      "I love our patients and am passionate about making sure they receive quality service and attention from start to finish.",
      "In my free time, I enjoy spending time with my husband and our kids. I love a nice glass of wine and to relax on a sunny beach.",
    ],
  },
];

// -------------------------------------------------------------------------
// REVIEWS — a fuller verbatim set than the Home page (which used Meagan, Ashley,
// Yoni). Quotes are EXACT from products.md, typos preserved (voice Rule 10,
// gotcha 12): "with with regards" (Tiffany), "then there" (Ed S), "bestest"
// (Yoni), and "Centennial Dentistry" (F G's own shortened wording). Attribution
// is as published — first name, or first name plus initial. No star ratings,
// dates, or platform labels are added (gotcha 15).
// -------------------------------------------------------------------------
const reviews = [
  {
    name: "Kailey",
    quote:
      "I’ll never go to another dentist again. Centennial Family Dentistry has been absolutely fantastic. I’m a chronic dentist-avoider due to dental anxiety, and didn’t go to the dentist for seven years. I went here for the first time 1.5 years ago. I have been here enough times since then, that I was comfortable to get Invisalign treatment as well! A highly personable dentist with stellar care & customer service!",
  },
  {
    name: "Tiffany",
    quote:
      "This place felt like a full service concierge dental office. Out of the gate my hygienist acknowledged that the dentist is most people’s least fave place and offers a blanket, pillow, etc and immediately helped to put my mind at ease and help me to relax. I can’t express enough how incredibly thorough they are with up to date technology with their x-rays, full scans and incredible attention to detail with with regards to my overall health, not just my teeth. It’s the most comprehensive dental exam I have ever had and my husband had the exact same experience at his first visit. We were both blown away and will be bringing our 5 year old here too. It’s honestly the first time in my life I won’t feel nervous to go back! Real talk!",
  },
  {
    name: "Nena",
    quote:
      "I can’t say how grateful I am to have such a wonderful dental office in my own town. I have had excellent dentists throughout my life, in my home state here and in NYC, and Centennial in Snohomish is at the top of that list. Drs. Rutherford and Greene and their staff are highly skillful and dedicated. They really look out for you, thinking long term, and doing work that’s necessary at the time while keeping watch on potential problem spots. The hygienists are wonderful. I really feel cared for in every way, as a patient and as a senior. They are very community-minded and a valuable asset to our area. Thank you, everybody at Centennial!",
  },
  {
    name: "William",
    quote:
      "I’ve been a patient at Centennial Family Dentistry since moving to Snohomish four years ago, and I couldn’t be more pleased with my experience. The entire staff and doctors are genuinely caring, take the time to listen, and always make me feel welcome. Their friendly and professional approach has made every visit a positive one. I highly recommend Centennial Family Dentistry for anyone looking for exceptional dental care.",
  },
  {
    name: "F G",
    quote:
      "5 STARS for the team at Centennial Dentistry! I recently had an issue with a crown; I was fortunate enough to get scheduled quickly and Dr. Greene was able to help me with a temporary. Her assistant Jessica was great to work with and took extra steps to make sure the temporary was fitted and comfortable. Everybody at this office is friendly, nice and professional!",
  },
  {
    name: "Taylor",
    quote:
      "This office is extremely kind and professional. They know how to make a dentist office an enjoyable experience! I had Invisalign done here as well, and they have been more than wonderful. I highly recommend them to anyone!",
  },
  {
    name: "Bob",
    quote:
      "The staff was very professional and knowledgeable. My hygienist did an awesome job cleaning my teeth and giving me educational tips and information.",
  },
  {
    name: "Kay",
    quote:
      "I have been going to Centennial Family Dentistry for many years. I’ve had standard cleanings and some major dental repairs and can’t imagine going anywhere else. Doctors, hygienists and staff are wonderful!",
  },
  {
    name: "Ed S",
    quote:
      "They are great and I will never go any other place then there they were so good from the start to the finish.",
  },
  {
    name: "Yoni",
    quote: "Dr. Gulrajani is the bestest.",
  },
];
---

<BaseLayout
  title="Meet the Team | Centennial Family Dentistry Snohomish (Concept Redesign)"
  description="Meet the dentists and staff at Centennial Family Dentistry in Snohomish, WA: Dr. Eve Rutherford, Dr. Rachel Greene, and Dr. Samiksha Gulrajani, and the team behind them."
>
  <!-- Page head -->
  <section class="container page-head" aria-labelledby="page-title">
    <p class="eyebrow">About Centennial Family Dentistry</p>
    <h1 id="page-title">Meet our team</h1>
  </section>

  <!-- The people: one flat flow, doctors first. Doctors sit on pale-green
       bands, staff on white — the background does the grouping quietly, the
       way the original site alternates band colors. -->
  <section aria-label="The team">
    <ul class="people" role="list">
      {
        people.map((person) => (
          <li class={`person ${person.doctor ? "person--doctor" : ""}`}>
            <div class="person__inner container">
              {person.photo ? (
                <img
                  class="person__photo"
                  src={img(person.photo)}
                  width={person.doctor ? 1000 : 600}
                  height={person.doctor ? 1074 : 800}
                  loading="lazy"
                  alt={person.name}
                />
              ) : (
                <div
                  class="person__photo person__photo--placeholder"
                  aria-hidden="true"
                >
                  <span>{person.name.charAt(0)}</span>
                </div>
              )}
              <div class="person__text">
                <h2 class="person__name">{person.name}</h2>
                {person.paras.map((p) => (
                  <p class="person__bio">{p}</p>
                ))}
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- The practice -->
  <section class="section practice" aria-labelledby="practice-title">
    <div class="container practice__grid">
      <div class="practice__text">
        <h2 id="practice-title" class="section__title">The practice</h2>
        <p class="practice__body">
          Centennial Family Dentistry is a Snohomish dental home focused on
          prevention, education, compassion, and meticulous dental care.
        </p>
        <p class="practice__body">
          Dr. Greene grew up in Snohomish and came back to practice in her own
          hometown. We look at your overall health, not just your teeth, and we
          publish our prices.
        </p>
        <p class="practice__body">
          The office is at 133 Maple Ave in Snohomish. To book an appointment,
          call <a href={tel}>360-568-6017</a>.
        </p>
      </div>
      <div class="practice__media">
        <img
          src={buildingImg}
          width="1600"
          height="900"
          loading="lazy"
          alt="The Centennial Family Dentistry building at 133 Maple Ave in Snohomish, Washington."
        />
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section reviews" aria-labelledby="reviews-title">
    <div class="container">
      <h2 id="reviews-title" class="section__title">
        What our patients are saying
      </h2>
      <ul class="reviews__list" role="list">
        {
          reviews.map((r) => (
            <li>
              <blockquote class="review">
                <p class="review__quote">{r.quote}</p>
                <cite class="review__cite">{r.name}</cite>
              </blockquote>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Socials + contact -->
  <section class="container section contact" aria-labelledby="contact-title">
    <h2 id="contact-title" class="section__title">Find us & say hello</h2>
    <div class="contact__grid">
      <div class="contact__col">
        <h3 class="contact__sub">Contact</h3>
        <address class="contact__address">
          133 Maple Ave<br />
          Snohomish WA 98290
        </address>
        <p class="contact__line">
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer">
            Get directions on Google Maps
          </a>
        </p>
        <p class="contact__line">
          <a href={tel}>Phone: 360-568-6017</a>
        </p>
        <p class="contact__line">
          <a href={`mailto:${email}`}>{email}</a>
        </p>
      </div>
      <div class="contact__col">
        <h3 class="contact__sub">Check us out on our socials</h3>
        <ul class="contact__socials" role="list">
          <li>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer">
              Instagram: @cfdentistrysnoho
            </a>
          </li>
          <li>
            <a href={facebookUrl} target="_blank" rel="noopener noreferrer">
              Facebook: /CFDsnohomish
            </a>
          </li>
        </ul>
        <h3 class="contact__sub contact__sub--spaced">Online Bill Pay</h3>
        <p class="contact__line">
          <a href={billPayUrl} target="_blank" rel="noopener noreferrer">
            Pay Here
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Page head ------------------------------------------------------------ */
  .page-head {
    padding-block: var(--space-2xl) var(--space-lg);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-green);
    margin-bottom: var(--space-sm);
  }

  .lede {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-body);
    color: var(--color-ink);
    margin-top: var(--space-md);
  }

  .page-head__cta {
    margin-top: var(--space-lg);
  }

  /* --- Shared section rhythm ------------------------------------------------ */
  .section {
    padding-block: var(--space-xl);
  }

  .section__title {
    color: var(--color-green);
  }

  .section__intro {
    margin-top: var(--space-sm);
    color: var(--color-ink);
  }

  /* --- The people ------------------------------------------------------------ */
  /* One flow, everyone a full-width band. Doctors on pale green, staff on
     white: the background groups them without headings. Identical band padding
     makes the spacing between every person exactly equal. */
  .people {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .person {
    padding-block: var(--space-xl);
    background: var(--color-surface);
  }

  .person--doctor {
    background: var(--color-paper);
  }

  .person__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    align-items: start;
  }

  .person__photo {
    width: 100%;
    /* Staff headshots are 3:4; shipped files are already framed correctly. */
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  /* Doctors: the practice's own near-square crops (1000x1074), shipped
     pre-cropped, so no CSS cropping at all. */
  .person--doctor .person__photo {
    aspect-ratio: 1000 / 1074;
  }

  .person__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    box-shadow: none;
  }

  .person__photo--placeholder span {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-green);
  }

  .person__name {
    font-size: var(--text-h3);
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  .person__bio {
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  /* --- The practice --------------------------------------------------------- */
  .practice {
    background: var(--color-paper);
    border-block: 1px solid var(--color-border);
  }

  .practice__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .practice__body {
    margin-top: var(--space-sm);
    color: var(--color-ink);
  }

  .practice__cta {
    margin-top: var(--space-lg);
  }

  .practice__media img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  /* --- Reviews -------------------------------------------------------------- */
  .reviews {
    border-block: 1px solid var(--color-border);
  }

  .reviews__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .review {
    height: 100%;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .review__quote {
    max-width: none;
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--color-ink);
  }

  .review__cite {
    display: block;
    margin-top: var(--space-md);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    font-style: normal;
    color: var(--color-green);
  }

  /* --- Socials + contact ---------------------------------------------------- */
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .contact__sub {
    margin-bottom: var(--space-sm);
  }

  .contact__sub--spaced {
    margin-top: var(--space-lg);
  }

  .contact__address {
    font-style: normal;
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  .contact__line {
    margin-bottom: var(--space-2xs);
  }

  .contact__line a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .contact__socials {
    list-style: none;
    padding: 0;
  }

  .contact__socials li {
    margin-bottom: var(--space-2xs);
  }

  .contact__socials a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .contact__cta {
    margin-top: var(--space-md);
  }

  /* --- Wider viewports (breakpoint 768, matching the shell) ----------------- */
  @media (min-width: 768px) {
    .person__inner {
      /* Original-scale portraits: staff ~460px; doctors a step larger. */
      grid-template-columns: 460px 1fr;
      gap: var(--space-xl);
    }

    .person--doctor .person__inner {
      grid-template-columns: 500px 1fr;
    }

    .practice__grid {
      grid-template-columns: 1fr 1fr;
    }

    .reviews__list {
      grid-template-columns: repeat(2, 1fr);
    }

    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
