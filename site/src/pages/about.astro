---

<BaseLayout
  title="Meet the Team | Centennial Family Dentistry Snohomish (Concept Redesign)"
  description="Meet the dentists and staff at Centennial Family Dentistry in Snohomish, WA: Dr. Eve Rutherford, Dr. Rachel Greene, and Dr. Samiksha Gulrajani, and the team behind them."
>
  <!-- Page head -->
  <section class="container page-head" aria-labelledby="page-title">
    <p class="eyebrow">About Centennial Family Dentistry</p>
    <h1 id="page-title">Meet our team</h1>
  </section>

  <!-- The people: one flat flow, doctors first. The photos carry the hierarchy. -->
  <section class="container section" aria-label="The team">
    <ul class="people" role="list">
      {
        people.map((person) => (
          <li class="person">
            {person.photo ? (
              <img
                class="person__photo"
                src={img(person.photo)}
                width="600"
                height="800"
                loading="lazy"
                alt={person.name}
              />
            ) : (
              <div
                class="person__photo person__photo--placeholder"
                aria-hidden="true"
              >
                <span>{person.name.charAt(0)}</span>
              </div>
            )}
            <div class="person__text">
              <h2 class="person__name">{person.name}</h2>
              {person.paras.map((p) => (
                <p class="person__bio">{p}</p>
              ))}
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- The practice -->
  <section class="section practice" aria-labelledby="practice-title">
    <div class="container practice__grid">
      <div class="practice__text">
        <h2 id="practice-title" class="section__title">The practice</h2>
        <p class="practice__body">
          Centennial Family Dentistry is a Snohomish dental home focused on
          prevention, education, compassion, and meticulous dental care.
        </p>
        <p class="practice__body">
          Dr. Greene grew up in Snohomish and came back to practice in her own
          hometown. We look at your overall health, not just your teeth, and we
          publish our prices.
        </p>
        <p class="practice__body">
          The office is at 133 Maple Ave in Snohomish. To book an appointment,
          call <a href={tel}>360-568-6017</a>.
        </p>
      </div>
      <div class="practice__media">
        <img
          src={buildingImg}
          width="1600"
          height="900"
          loading="lazy"
          alt="The Centennial Family Dentistry building at 133 Maple Ave in Snohomish, Washington."
        />
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section reviews" aria-labelledby="reviews-title">
    <div class="container">
      <h2 id="reviews-title" class="section__title">
        What our patients are saying
      </h2>
      <ul class="reviews__list" role="list">
        {
          reviews.map((r) => (
            <li>
              <blockquote class="review">
                <p class="review__quote">{r.quote}</p>
                <cite class="review__cite">{r.name}</cite>
              </blockquote>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Socials + contact -->
  <section class="container section contact" aria-labelledby="contact-title">
    <h2 id="contact-title" class="section__title">Find us & say hello</h2>
    <div class="contact__grid">
      <div class="contact__col">
        <h3 class="contact__sub">Contact</h3>
        <address class="contact__address">
          133 Maple Ave<br />
          Snohomish WA 98290
        </address>
        <p class="contact__line">
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer">
            Get directions on Google Maps
          </a>
        </p>
        <p class="contact__line">
          <a href={tel}>Phone: 360-568-6017</a>
        </p>
        <p class="contact__line">
          <a href={`mailto:${email}`}>{email}</a>
        </p>
      </div>
      <div class="contact__col">
        <h3 class="contact__sub">Check us out on our socials</h3>
        <ul class="contact__socials" role="list">
          <li>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer">
              Instagram: @cfdentistrysnoho
            </a>
          </li>
          <li>
            <a href={facebookUrl} target="_blank" rel="noopener noreferrer">
              Facebook: /CFDsnohomish
            </a>
          </li>
        </ul>
        <h3 class="contact__sub contact__sub--spaced">Online Bill Pay</h3>
        <p class="contact__line">
          <a href={billPayUrl} target="_blank" rel="noopener noreferrer">
            Pay Here
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Page head ------------------------------------------------------------ */
  .page-head {
    padding-block: var(--space-2xl) var(--space-lg);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-green);
    margin-bottom: var(--space-sm);
  }

  .lede {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-body);
    color: var(--color-ink);
    margin-top: var(--space-md);
  }

  .page-head__cta {
    margin-top: var(--space-lg);
  }

  /* --- Shared section rhythm ------------------------------------------------ */
  .section {
    padding-block: var(--space-xl);
  }

  .section__title {
    color: var(--color-green);
  }

  .section__intro {
    margin-top: var(--space-sm);
    color: var(--color-ink);
  }

  /* --- The people ------------------------------------------------------------ */
  /* One flow, everyone in the same row format: large portrait beside the bio.
     Uniform vertical rhythm keeps every photo evenly spaced. */
  .people {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  .person {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    align-items: start;
  }

  .person__photo {
    width: 100%;
    /* Portrait crop matched to the source headshots (mostly 3:4). Square-cropping
       lopped the tops of heads (Dr. Greene's is a taller 2:3); object-position
       biased upward keeps every face intact. */
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: 50% 15%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .person__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    box-shadow: none;
  }

  .person__photo--placeholder span {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-green);
  }

  .person__name {
    font-size: var(--text-h3);
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  .person__bio {
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  /* --- The practice --------------------------------------------------------- */
  .practice {
    background: var(--color-paper);
    border-block: 1px solid var(--color-border);
  }

  .practice__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .practice__body {
    margin-top: var(--space-sm);
    color: var(--color-ink);
  }

  .practice__cta {
    margin-top: var(--space-lg);
  }

  .practice__media img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  /* --- Reviews -------------------------------------------------------------- */
  .reviews {
    border-block: 1px solid var(--color-border);
  }

  .reviews__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .review {
    height: 100%;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .review__quote {
    max-width: none;
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--color-ink);
  }

  .review__cite {
    display: block;
    margin-top: var(--space-md);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    font-style: normal;
    color: var(--color-green);
  }

  /* --- Socials + contact ---------------------------------------------------- */
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .contact__sub {
    margin-bottom: var(--space-sm);
  }

  .contact__sub--spaced {
    margin-top: var(--space-lg);
  }

  .contact__address {
    font-style: normal;
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  .contact__line {
    margin-bottom: var(--space-2xs);
  }

  .contact__line a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .contact__socials {
    list-style: none;
    padding: 0;
  }

  .contact__socials li {
    margin-bottom: var(--space-2xs);
  }

  .contact__socials a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .contact__cta {
    margin-top: var(--space-md);
  }

  /* --- Wider viewports (breakpoint 768, matching the shell) ----------------- */
  @media (min-width: 768px) {
    .person {
      /* Original-scale portraits: the photo column is ~460px of the 1120px
         container, close to the source site's 559px-wide headshot display. */
      grid-template-columns: 460px 1fr;
      gap: var(--space-xl);
    }

    .practice__grid {
      grid-template-columns: 1fr 1fr;
    }

    .reviews__list {
      grid-template-columns: repeat(2, 1fr);
    }

    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
