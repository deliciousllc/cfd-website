---
import BaseLayout from "../layouts/BaseLayout.astro";

// Base-aware URLs. On GitHub Pages everything sits under /cfd-website; only
// Astro frontmatter can read import.meta.env.BASE_URL. Hardcoded paths 404.
const base = import.meta.env.BASE_URL;
const b = base.endsWith("/") ? base : base + "/";
const img = (file: string) => b + "images/" + file;
const buildingImg = img("building.jpg");

const tel = "tel:360-568-6017";

// External + social links — verbatim from products.md (Contact & location).
const instagramUrl = "https://www.instagram.com/cfdentistrysnoho/";
const facebookUrl = "https://www.facebook.com/CFDsnohomish/";
const billPayUrl = "https://bestcardteam.com/Payments/?Profile=centennialfamPAY";
const email = "info@cfdentistrysnohomish.com";

// Google Maps link to the verbatim address (same convention as the Home page:
// no map is stated on the source site, so this is a redesign-added convenience
// link, not a quoted fact — the address string itself is verbatim).
const mapsUrl =
  "https://www.google.com/maps/search/?api=1&query=133+Maple+Ave+Snohomish+WA+98290";

// -------------------------------------------------------------------------
// THE DOCTORS — three, names/credentials verbatim from products.md (gotcha 11).
// Photos matched to each person by the capture-log filename map (assets/
// dr-eve-rutherford.jpg etc.), GPS/EXIF stripped before shipping.
// Bios are REWRITTEN from the about-us evidence: first-person-singular and the
// "form Scripps" typo are cleaned (phrasing), but every FACT — school, degree,
// role, community service, practice days — is preserved exactly. Nothing here
// is invented (voice Rule 10).
// -------------------------------------------------------------------------
const doctors = [
  {
    name: "Dr. Eve Rutherford DDS",
    photo: "dr-eve-rutherford.jpg",
    alt: "Dr. Eve Rutherford",
    bio: [
      "Dr. Rutherford earned her dental degree at the University of Washington School of Dentistry, after a Bachelor of Arts with Honors in Biology from Scripps College in Claremont, California. Before dental school she worked in the University of Washington’s Department of Pathology, studying connective tissue disorders. She was raised in Kalispell, Montana, and graduated from Flathead High School.",
      "Her work reaches past the office. She has served on the Board of Directors for the Washington Dental Service Foundation since 2015, sat on a 2016 Washington State Health Care Authority task force to improve Adult Dental Medicaid benefits, stays active with the ABCD Program (Access to Baby and Child Dentistry), and is Affiliate Faculty for the University of Washington Department of Pediatric Dentistry.",
    ],
    schedule: "Practices Mondays, Tuesdays, Wednesdays, and Thursdays.",
  },
  {
    name: "Dr. Rachel Greene DDS",
    photo: "dr-rachel-greene.jpg",
    alt: "Dr. Rachel Greene",
    bio: [
      "Dr. Rachel (Krell) Greene graduated from the University of Michigan School of Dentistry, after a Bachelor of Arts with Honors in Science, Technology and Society from the University of Puget Sound. She was born and raised in Snohomish and came home to practice in the town she grew up in.",
      "She is also a professor at the University of Washington School of Dentistry, serving as Clinical Director of Western Washington for the Service Learning Program and as a Clinical Instructor in the student patient clinic. If the dentist makes you anxious, she gets it — she’ll work with you to find the most comfortable way through your care.",
    ],
    schedule: "Practices on Thursdays and Fridays by appointment.",
  },
  {
    name: "Dr. Samiksha Gulrajani DMD",
    photo: "dr-samiksha-gulrajani.jpg",
    alt: "Dr. Samiksha Gulrajani",
    bio: [
      "Dr. Gulrajani is originally from Cincinnati, Ohio. She completed undergraduate studies in Mathematics and Neuroscience at the University of Pittsburgh, graduating with honors and a minor in Chemistry, then earned her Doctor of Dental Medicine (DMD) at the University of Pittsburgh School of Dental Medicine.",
      "She went on to a residency in Advanced Education in General Dentistry (AEGD), treating complex cases at the university and at a local urgent care clinic. She specializes in comprehensive dental care, with a particular focus on patients with special needs.",
    ],
    schedule: "Practices on Monday, Tuesday, and Wednesday.",
  },
];

// -------------------------------------------------------------------------
// THE TEAM — every hygienist, assistant, and coordinator by name (voice Rule 1:
// named people, never "our team"). Names and titles verbatim from products.md.
// One-line descriptions are rewritten from the about-us bios, facts preserved.
// Photos matched by the capture-log filename map, GPS/EXIF stripped.
// "Practice Business manager" (lowercase m on the source) is title-cased here as
// a deliberate copy-editing choice, not a fact change (gotcha 16).
// Becca has no real photo (the source uses the practice logo as a placeholder
// and her bio reads only "Details coming soon!"), so she gets a clean text-only
// card rather than a substituted face (brief rule).
// -------------------------------------------------------------------------
const team = [
  {
    name: "Brooke",
    title: "Dental Hygienist",
    photo: "brooke.jpg",
    line: "A hygienist here since 2018, bringing 10 years of experience.",
  },
  {
    name: "Savannah",
    title: "Dental Hygienist",
    photo: "savannah.jpg",
    line: "Born and raised in Kirkland; on the Centennial team since 2021, with a bachelor’s from Seattle Central.",
  },
  {
    name: "Juliana",
    title: "Dental Hygienist",
    photo: "juliana.jpg",
    line: "Originally from Florida, with a biology degree from Nova Southeastern and a dental hygiene degree.",
  },
  {
    name: "Becca",
    title: "Dental Hygienist",
    photo: null,
    line: "Details coming soon!",
  },
  {
    name: "Amaya",
    title: "Dental Assistant",
    photo: "amaya.jpg",
    line: "Graduated the West Coast College of Dental Assisting in 2022.",
  },
  {
    name: "Jessica",
    title: "Dental Assistant",
    photo: "jessica.jpg",
    line: "Joined in 2021 with over 15 years of experience; she’s the one Invisalign patients see every six weeks.",
  },
  {
    name: "Kadi",
    title: "Dental Assistant",
    photo: "kadi.jpg",
    line: "Joined in 2024, and especially loves helping patients with anxiety have a good visit.",
  },
  {
    name: "Yana",
    title: "Scheduling Coordinator",
    photo: "yana.jpg",
    line: "With the office since 2024; she runs the office’s Kids’ Days.",
  },
  {
    name: "Ciara",
    title: "Scheduling Coordinator",
    photo: "ciara.jpg",
    line: "Joined in 2024 with 6 years of scheduling and insurance-billing experience; grew up in Lake Stevens.",
  },
  {
    name: "Kayleen",
    title: "Scheduling Coordinator",
    photo: "kayleen.jpg",
    line: "Joined in 2025 with 8 years of experience and a background in personal banking; grew up in Lake Stevens.",
  },
  {
    name: "Molly",
    title: "Financial Coordinator",
    photo: "molly.jpg",
    line: "Joined in 2023 with three years in dental billing; she also holds a Dental Assisting license.",
  },
  {
    name: "Marne",
    title: "Practice Business Manager",
    photo: "marne.jpg",
    line: "Keeps the practice running so your care goes smoothly from start to finish.",
  },
];

// -------------------------------------------------------------------------
// REVIEWS — a fuller verbatim set than the Home page (which used Meagan, Ashley,
// Yoni). Quotes are EXACT from products.md, typos preserved (voice Rule 10,
// gotcha 12): "with with regards" (Tiffany), "then there" (Ed S), "bestest"
// (Yoni), and "Centennial Dentistry" (F G's own shortened wording). Attribution
// is as published — first name, or first name plus initial. No star ratings,
// dates, or platform labels are added (gotcha 15).
// -------------------------------------------------------------------------
const reviews = [
  {
    name: "Kailey",
    quote:
      "I’ll never go to another dentist again. Centennial Family Dentistry has been absolutely fantastic. I’m a chronic dentist-avoider due to dental anxiety, and didn’t go to the dentist for seven years. I went here for the first time 1.5 years ago. I have been here enough times since then, that I was comfortable to get Invisalign treatment as well! A highly personable dentist with stellar care & customer service!",
  },
  {
    name: "Tiffany",
    quote:
      "This place felt like a full service concierge dental office. Out of the gate my hygienist acknowledged that the dentist is most people’s least fave place and offers a blanket, pillow, etc and immediately helped to put my mind at ease and help me to relax. I can’t express enough how incredibly thorough they are with up to date technology with their x-rays, full scans and incredible attention to detail with with regards to my overall health, not just my teeth. It’s the most comprehensive dental exam I have ever had and my husband had the exact same experience at his first visit. We were both blown away and will be bringing our 5 year old here too. It’s honestly the first time in my life I won’t feel nervous to go back! Real talk!",
  },
  {
    name: "Nena",
    quote:
      "I can’t say how grateful I am to have such a wonderful dental office in my own town. I have had excellent dentists throughout my life, in my home state here and in NYC, and Centennial in Snohomish is at the top of that list. Drs. Rutherford and Greene and their staff are highly skillful and dedicated. They really look out for you, thinking long term, and doing work that’s necessary at the time while keeping watch on potential problem spots. The hygienists are wonderful. I really feel cared for in every way, as a patient and as a senior. They are very community-minded and a valuable asset to our area. Thank you, everybody at Centennial!",
  },
  {
    name: "William",
    quote:
      "I’ve been a patient at Centennial Family Dentistry since moving to Snohomish four years ago, and I couldn’t be more pleased with my experience. The entire staff and doctors are genuinely caring, take the time to listen, and always make me feel welcome. Their friendly and professional approach has made every visit a positive one. I highly recommend Centennial Family Dentistry for anyone looking for exceptional dental care.",
  },
  {
    name: "F G",
    quote:
      "5 STARS for the team at Centennial Dentistry! I recently had an issue with a crown; I was fortunate enough to get scheduled quickly and Dr. Greene was able to help me with a temporary. Her assistant Jessica was great to work with and took extra steps to make sure the temporary was fitted and comfortable. Everybody at this office is friendly, nice and professional!",
  },
  {
    name: "Taylor",
    quote:
      "This office is extremely kind and professional. They know how to make a dentist office an enjoyable experience! I had Invisalign done here as well, and they have been more than wonderful. I highly recommend them to anyone!",
  },
  {
    name: "Bob",
    quote:
      "The staff was very professional and knowledgeable. My hygienist did an awesome job cleaning my teeth and giving me educational tips and information.",
  },
  {
    name: "Kay",
    quote:
      "I have been going to Centennial Family Dentistry for many years. I’ve had standard cleanings and some major dental repairs and can’t imagine going anywhere else. Doctors, hygienists and staff are wonderful!",
  },
  {
    name: "Ed S",
    quote:
      "They are great and I will never go any other place then there they were so good from the start to the finish.",
  },
  {
    name: "Yoni",
    quote: "Dr. Gulrajani is the bestest.",
  },
];
---

<BaseLayout
  title="Meet the Team | Centennial Family Dentistry Snohomish"
  description="Meet the dentists and staff at Centennial Family Dentistry in Snohomish, WA — Dr. Eve Rutherford, Dr. Rachel Greene, and Dr. Samiksha Gulrajani, and the team behind them."
>
  <!-- Page head -->
  <section class="container page-head" aria-labelledby="page-title">
    <p class="eyebrow">About Centennial Family Dentistry</p>
    <h1 id="page-title">Meet the team</h1>
    <p class="lede">
      Care here has a first name. Three dentists, and every hygienist and
      coordinator behind them, so you’ll know who you’re seeing before you sit
      down.
    </p>
    <a class="btn-call page-head__cta" href={tel}>Call 360-568-6017</a>
  </section>

  <!-- The doctors -->
  <section class="container section" aria-labelledby="doctors-title">
    <h2 id="doctors-title" class="section__title">The doctors</h2>
    <div class="doctors">
      {
        doctors.map((d) => (
          <article class="doctor">
            <img
              class="doctor__photo"
              src={img(d.photo)}
              width="600"
              height="600"
              loading="lazy"
              alt={d.alt}
            />
            <div class="doctor__text">
              <h3 class="doctor__name">{d.name}</h3>
              {d.bio.map((p) => (
                <p class="doctor__bio">{p}</p>
              ))}
              <p class="doctor__schedule">{d.schedule}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- The team -->
  <section class="container section" aria-labelledby="team-title">
    <h2 id="team-title" class="section__title">The rest of the team</h2>
    <p class="section__intro">
      The hygienists, assistants, and coordinators who’ll clean your teeth, sit
      with you in the chair, and answer the phone when you call.
    </p>
    <ul class="team" role="list">
      {
        team.map((m) => (
          <li class="member">
            {m.photo ? (
              <img
                class="member__photo"
                src={img(m.photo)}
                width="600"
                height="600"
                loading="lazy"
                alt={`${m.name}, ${m.title.toLowerCase()}`}
              />
            ) : (
              <div class="member__photo member__photo--placeholder" aria-hidden="true">
                <span>{m.name.charAt(0)}</span>
              </div>
            )}
            <h3 class="member__name">{m.name}</h3>
            <p class="member__title">{m.title}</p>
            <p class="member__line">{m.line}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- The practice -->
  <section class="section practice" aria-labelledby="practice-title">
    <div class="container practice__grid">
      <div class="practice__text">
        <h2 id="practice-title" class="section__title">The practice</h2>
        <p class="practice__body">
          Centennial Family Dentistry is a Snohomish dental home focused on
          prevention, education, compassion, and meticulous dental care.
        </p>
        <p class="practice__body">
          Dr. Greene grew up in Snohomish and came back to practice in her own
          hometown. We look at your overall health, not just your teeth — and we
          publish our prices, so you know what care costs before you’re in the
          chair.
        </p>
        <p class="practice__body">
          You’ll find us at 133 Maple Ave in Snohomish. To book, call the office
          — there’s no form and no phone tree, just our front desk.
        </p>
        <a class="btn-call practice__cta" href={tel}>Call 360-568-6017</a>
      </div>
      <div class="practice__media">
        <img
          src={buildingImg}
          width="1600"
          height="900"
          loading="lazy"
          alt="The Centennial Family Dentistry building at 133 Maple Ave in Snohomish, Washington."
        />
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section reviews" aria-labelledby="reviews-title">
    <div class="container">
      <h2 id="reviews-title" class="section__title">
        What our patients are saying
      </h2>
      <ul class="reviews__list" role="list">
        {
          reviews.map((r) => (
            <li>
              <blockquote class="review">
                <p class="review__quote">{r.quote}</p>
                <cite class="review__cite">{r.name}</cite>
              </blockquote>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Socials + contact -->
  <section class="container section contact" aria-labelledby="contact-title">
    <h2 id="contact-title" class="section__title">Find us & say hello</h2>
    <div class="contact__grid">
      <div class="contact__col">
        <h3 class="contact__sub">Contact</h3>
        <address class="contact__address">
          133 Maple Ave<br />
          Snohomish WA 98290
        </address>
        <p class="contact__line">
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer">
            Get directions on Google Maps
          </a>
        </p>
        <p class="contact__line">
          <a href={tel}>Phone: 360-568-6017</a>
        </p>
        <p class="contact__line">
          <a href={`mailto:${email}`}>{email}</a>
        </p>
        <a class="btn-call contact__cta" href={tel}>Call 360-568-6017</a>
      </div>
      <div class="contact__col">
        <h3 class="contact__sub">Check us out on our socials</h3>
        <ul class="contact__socials" role="list">
          <li>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer">
              Instagram: @cfdentistrysnoho
            </a>
          </li>
          <li>
            <a href={facebookUrl} target="_blank" rel="noopener noreferrer">
              Facebook: /CFDsnohomish
            </a>
          </li>
        </ul>
        <h3 class="contact__sub contact__sub--spaced">Online Bill Pay</h3>
        <p class="contact__line">
          <a href={billPayUrl} target="_blank" rel="noopener noreferrer">
            Pay Here
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Page head ------------------------------------------------------------ */
  .page-head {
    padding-block: var(--space-2xl) var(--space-lg);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-green);
    margin-bottom: var(--space-sm);
  }

  .lede {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-body);
    color: var(--color-ink);
    margin-top: var(--space-md);
  }

  .page-head__cta {
    margin-top: var(--space-lg);
  }

  /* --- Shared section rhythm ------------------------------------------------ */
  .section {
    padding-block: var(--space-xl);
  }

  .section__title {
    color: var(--color-green);
  }

  .section__intro {
    margin-top: var(--space-sm);
    color: var(--color-ink);
  }

  /* --- The doctors ---------------------------------------------------------- */
  .doctors {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .doctor {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .doctor__photo {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .doctor__name {
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  .doctor__bio {
    margin-bottom: var(--space-sm);
    color: var(--color-ink);
  }

  .doctor__schedule {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink-muted);
    margin-top: var(--space-xs);
  }

  /* --- The team ------------------------------------------------------------- */
  .team {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg) var(--space-md);
    margin-top: var(--space-lg);
  }

  .member {
    display: flex;
    flex-direction: column;
  }

  .member__photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .member__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    box-shadow: none;
  }

  .member__photo--placeholder span {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-green);
  }

  .member__name {
    font-size: var(--text-h3);
    color: var(--color-ink);
    margin-top: var(--space-sm);
  }

  .member__title {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-green);
    margin-top: var(--space-3xs);
  }

  .member__line {
    font-size: var(--text-sm);
    color: var(--color-ink);
    margin-top: var(--space-2xs);
  }

  /* --- The practice --------------------------------------------------------- */
  .practice {
    background: var(--color-paper);
    border-block: 1px solid var(--color-border);
  }

  .practice__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .practice__body {
    margin-top: var(--space-sm);
    color: var(--color-ink);
  }

  .practice__cta {
    margin-top: var(--space-lg);
  }

  .practice__media img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  /* --- Reviews -------------------------------------------------------------- */
  .reviews {
    border-block: 1px solid var(--color-border);
  }

  .reviews__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .review {
    height: 100%;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .review__quote {
    max-width: none;
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--color-ink);
  }

  .review__cite {
    display: block;
    margin-top: var(--space-md);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    font-style: normal;
    color: var(--color-green);
  }

  /* --- Socials + contact ---------------------------------------------------- */
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .contact__sub {
    margin-bottom: var(--space-sm);
  }

  .contact__sub--spaced {
    margin-top: var(--space-lg);
  }

  .contact__address {
    font-style: normal;
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  .contact__line {
    margin-bottom: var(--space-2xs);
  }

  .contact__line a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .contact__socials {
    list-style: none;
    padding: 0;
  }

  .contact__socials li {
    margin-bottom: var(--space-2xs);
  }

  .contact__socials a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .contact__cta {
    margin-top: var(--space-md);
  }

  /* --- Wider viewports (breakpoint 768, matching the shell) ----------------- */
  @media (min-width: 768px) {
    .doctor {
      grid-template-columns: 260px 1fr;
      gap: var(--space-xl);
      align-items: start;
    }

    .doctor__photo {
      max-width: 260px;
    }

    .team {
      grid-template-columns: repeat(4, 1fr);
    }

    .practice__grid {
      grid-template-columns: 1fr 1fr;
    }

    .reviews__list {
      grid-template-columns: repeat(2, 1fr);
    }

    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
