---
import BaseLayout from "../layouts/BaseLayout.astro";

// Base-aware URLs. CSS/markup on GitHub Pages must respect the /cfd-website base;
// a hardcoded "/services" or "/images/x.jpg" 404s. Only Astro frontmatter can
// read import.meta.env.BASE_URL.
const base = import.meta.env.BASE_URL;
const b = base.endsWith("/") ? base : base + "/";
const servicesUrl = b + "services/";
const aboutUrl = b + "about/";

const tel = "tel:360-568-6017";

// Hero carousel — mirrors the source site, whose hero is a cycling photo
// carousel. Slides are the practice's own photos (brand/_sources capture logs,
// 2026-07-22 and 2026-07-23), people first. Click a photo to view it large;
// the edges step through; swipe works on touch.
const slides = [
  {
    src: b + "images/team-huskies.jpg",
    w: 1600,
    h: 1200,
    alt:
      "The Centennial Family Dentistry team, five staff members in University of Washington Huskies shirts, together in the office.",
  },
  {
    src: b + "images/team-dsworld.jpg",
    w: 1600,
    h: 1200,
    alt:
      "The full Centennial Family Dentistry team standing in front of the giant DS World letters at a dental conference.",
  },
  {
    src: b + "images/team-hawaii.jpg",
    w: 1600,
    h: 1200,
    alt:
      "Team members in Hawaiian-print shirts and flower leis at the office's front door.",
  },
  {
    src: b + "images/team-costumes.jpg",
    w: 1600,
    h: 1200,
    alt:
      "The team in inflatable animal costumes lined up outside the office building.",
  },
  {
    src: b + "images/team-happy-camper.jpg",
    w: 1600,
    h: 2133,
    alt:
      "Four team members at the front desk under a Happy Camper banner during a themed Kids' Day.",
  },
  {
    src: b + "images/building-balloon.jpg",
    w: 1600,
    h: 1205,
    alt:
      "The front of the Centennial Family Dentistry building on a clear day, a hot air balloon drifting in the sky above.",
  },
];

// Doctor headshots for the home teaser (same files the About page uses).
const doctorCards = [
  { name: "Dr. Eve Rutherford DDS", photo: b + "images/dr-eve-rutherford.jpg" },
  { name: "Dr. Rachel Greene DDS", photo: b + "images/dr-rachel-greene.jpg" },
  {
    name: "Dr. Samiksha Gulrajani DMD",
    photo: b + "images/dr-samiksha-gulrajani.jpg",
  },
];

// Google Maps link to the verbatim practice address (products.md: no map is
// stated on the source site, so this is a redesign-added convenience link, not
// a quoted fact — the address string itself is verbatim).
const mapsUrl =
  "https://www.google.com/maps/search/?api=1&query=133+Maple+Ave+Snohomish+WA+98290";

// The five Task-2 service groups. Names and anchor IDs are LOCKED by
// service-inventory.md — never rename or re-slug. Descriptions are rewritten
// from the practice's own service copy (products.md); no contested price appears
// here — pricing lives on the Services page.
const services = [
  {
    name: "Routine care",
    anchor: "routine-care",
    body:
      "Cleanings and exams every six months. X-rays, a gentle cleaning, and a hygienist who shows you how to keep decay and gum disease away at home.",
  },
  {
    name: "Restorative",
    anchor: "restorative",
    body:
      "Fillings, crowns, and extractions to get a sore or damaged tooth healthy again.",
  },
  {
    name: "Cosmetic",
    anchor: "cosmetic",
    body:
      "Whitening, veneers, and Invisalign to renew your smile, plus Botox and fillers, whether or not you’re a patient here.",
  },
  {
    name: "Sleep & TMJ",
    anchor: "sleep-tmj",
    body:
      "At-home sleep testing and custom oral appliances for sleep apnea, and relief for the jaw pain, clicking, and headaches of TMJ.",
  },
  {
    name: "Technology & extras",
    anchor: "technology-extras",
    body:
      "3D-printed night guards made in-house, gentle laser treatment, the Willo brushing system, and themed Kids’ Days for younger patients.",
  },
];

// 2–3 patient reviews, verbatim from products.md (gotcha 12: typos preserved,
// e.g. "bestest"). Attribution as published (first name / first name + initial).
const reviews = [
  {
    name: "Meagan",
    quote:
      "I highly recommend Centennial Family Dentistry to anyone who feels anxious about going to the dentist. The staff is incredibly patient and understanding, and they take the time to answer all of my questions. They’ve made me feel so comfortable that I’ve even recommended them to several friends and family members.",
  },
  {
    name: "Ashley",
    quote:
      "Hands down the best dental experience I’ve ever had. The dental assistant and Dr. Greene were exceptional and made me feel so comfortable. What a cozy, homey dental office. I actually can’t wait for my next appointment!",
  },
  {
    name: "Yoni",
    quote: "Dr. Gulrajani is the bestest.",
  },
];

// Hours — verbatim from products.md (inconsistent abbreviations and the missing
// "am" on Thursday are intentional, reproduced exactly).
const hours = [
  "Mon: 7:30am-4:00pm",
  "Tues: 8:00am-4:30pm",
  "Wednesday: 7:30am-5:00pm",
  "Thursday: 7:30-4:00pm",
  "Friday: By Appointment Only",
  "Saturday & Sunday: Closed",
];
---

<BaseLayout
  title="Home | Centennial Family Dentistry Snohomish (Concept Redesign)"
  description="Centennial Family Dentistry. We are a Snohomish dentist here to provide a dental home focused on prevention, education, compassion and meticulous dental care"
>
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero__inner container">
      <div class="hero__text">
        <p class="eyebrow">Family dentistry in Snohomish, Washington</p>
        <h1 id="hero-title">Centennial Family Dentistry</h1>
        <p class="hero__lede">
          A dental home focused on prevention, education, compassion, and
          meticulous dental care.
        </p>
        <p class="hero__doctors">
          The office of Dr. Eve Rutherford DDS, Dr. Rachel Greene DDS, and Dr.
          Samiksha Gulrajani DMD.
        </p>
      </div>

      <div class="carousel" data-carousel>
        <ul class="carousel__slides" role="list">
          {
            slides.map((s, i) => (
              <li
                class={`carousel__slide${i === 0 ? " is-active" : ""}`}
                data-slide
              >
                <img
                  src={s.src}
                  width={s.w}
                  height={s.h}
                  alt={s.alt}
                  loading={i === 0 ? "eager" : "lazy"}
                />
              </li>
            ))
          }
        </ul>
        <!-- Invisible interaction zones: edges step, the middle opens the photo
             large. Real buttons, so keyboard users get them too. -->
        <button
          class="carousel__zone carousel__zone--prev"
          type="button"
          data-prev
          aria-label="Previous photo"
        ></button>
        <button
          class="carousel__zone carousel__zone--open"
          type="button"
          data-open
          aria-label="View photo larger"
        ></button>
        <button
          class="carousel__zone carousel__zone--next"
          type="button"
          data-next
          aria-label="Next photo"
        ></button>
      </div>
    </div>
  </section>

  <!-- Lightbox for the hero photos -->
  <div class="lightbox" data-lightbox hidden>
    <button
      class="lightbox__close"
      type="button"
      data-close
      aria-label="Close photo view"
    >&times;</button>
    <img class="lightbox__img" data-lightbox-img src="" alt="" />
  </div>

  <!-- Services overview -->
  <section class="section container" aria-labelledby="services-title">
    <div class="section__head">
      <h2 id="services-title">What we do</h2>
      <a class="section__link" href={servicesUrl}>See all services &amp; prices</a>
    </div>
    <ul class="cards" role="list">
      {
        services.map((s) => (
          <li class="card-item">
            <a class="card" href={`${servicesUrl}#${s.anchor}`}>
              <h3 class="card__title">{s.name}</h3>
              <p class="card__body">{s.body}</p>
              <span class="card__more" aria-hidden="true">See details &amp; pricing &rarr;</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- The doctors -->
  <section class="section container" aria-labelledby="doctors-title">
    <div class="section__head">
      <h2 id="doctors-title">The doctors</h2>
      <a class="section__link" href={aboutUrl}>Meet the whole team</a>
    </div>
    <ul class="doctor-cards" role="list">
      {
        doctorCards.map((d) => (
          <li class="doctor-card">
            <a href={aboutUrl}>
              <img
                src={d.photo}
                width="600"
                height="800"
                loading="lazy"
                alt={d.name}
              />
              <span class="doctor-card__name">{d.name}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Reviews strip -->
  <section class="section reviews" aria-labelledby="reviews-title">
    <div class="container">
      <h2 id="reviews-title">See what our patients are saying</h2>
      <ul class="reviews__list" role="list">
        {
          reviews.map((r) => (
            <li>
              <blockquote class="review">
                <p class="review__quote">{r.quote}</p>
                <cite class="review__cite">{r.name}</cite>
              </blockquote>
            </li>
          ))
        }
      </ul>
      <a class="section__link" href={aboutUrl}>Read more patient reviews</a>
    </div>
  </section>

  <!-- Visit us -->
  <section class="section container" aria-labelledby="visit-title">
    <h2 id="visit-title">Visit us</h2>
    <div class="visit">
      <div class="visit__col">
        <h3 class="visit__sub">Hours of Operation</h3>
        <ul class="visit__hours" role="list">
          {hours.map((h) => <li>{h}</li>)}
        </ul>
      </div>
      <div class="visit__col">
        <h3 class="visit__sub">Find us</h3>
        <address class="visit__address">
          133 Maple Ave<br />
          Snohomish WA 98290
        </address>
        <p class="visit__line">
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer">
            Get directions on Google Maps
          </a>
        </p>
        <p class="visit__line">
          <a href={tel}>Phone: 360-568-6017</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Shared section rhythm ------------------------------------------------ */
  .section {
    padding-block: var(--space-2xl);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-green);
    margin-bottom: var(--space-sm);
  }

  .section__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .section__link {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-green);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    white-space: nowrap;
  }

  .section__link:hover {
    color: var(--color-green-deep);
  }

  /* --- Hero: drenched evergreen -------------------------------------------- */
  .hero {
    /* Full-bleed band: the practice's deep green carries the whole hero, so the
       page opens with their color, not a wall of white. */
    background: var(--color-green-deep);
    color: var(--color-paper);
    padding-block: var(--space-2xl);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    /* Stretch, not center: the text column matches the image height, with the
       title at the image's top edge and the doctors line at its bottom. */
    align-items: stretch;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
  }

  .hero__text h1 {
    margin-bottom: auto;
  }

  .hero .eyebrow {
    /* Pale sage keeps the brand's tree-green warmth but clears AA on the deep
       green band (4.98:1); full sage would fail small-text contrast (3.46). */
    color: #cdd6b0;
  }

  .hero__text h1 {
    color: var(--color-paper);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .hero__lede {
    font-size: var(--text-lg);
    line-height: var(--leading-body);
    color: var(--color-paper);
    margin-top: var(--space-md);
  }

  .hero__doctors {
    font-size: var(--text-base);
    /* Cream held at full strength for AA on green; hierarchy comes from size. */
    color: var(--color-paper);
    opacity: 0.82;
    margin-top: var(--space-md);
  }

  /* --- Hero carousel --------------------------------------------------------- */
  .carousel {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 18px 40px -20px rgba(0, 0, 0, 0.55);
  }

  .carousel__slides {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    aspect-ratio: 3 / 2;
    height: 100%;
  }

  .carousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .carousel__slide.is-active {
    opacity: 1;
  }

  .carousel__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Invisible interaction zones. Edge zones show a directional cursor; the
     middle shows zoom-in. No visible chrome. */
  .carousel__zone {
    appearance: none;
    border: none;
    background: transparent;
    padding: 0;
    position: absolute;
    top: 0;
    bottom: 0;
    z-index: 2;
  }

  .carousel__zone--prev {
    left: 0;
    width: 22%;
    cursor: w-resize;
  }

  .carousel__zone--next {
    right: 0;
    width: 22%;
    cursor: e-resize;
  }

  .carousel__zone--open {
    left: 22%;
    width: 56%;
    cursor: zoom-in;
  }

  /* --- Lightbox --------------------------------------------------------------- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: rgba(26, 20, 24, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md);
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox__img {
    max-width: min(1600px, 96vw);
    max-height: 92vh;
    width: auto;
    height: auto;
    border-radius: var(--radius);
    box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.8);
  }

  .lightbox__close {
    appearance: none;
    border: none;
    background: transparent;
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    color: var(--color-paper);
    font-size: 2.25rem;
    line-height: 1;
    padding: var(--space-2xs) var(--space-xs);
    min-width: 44px;
    min-height: 44px;
    cursor: pointer;
    border-radius: var(--radius);
  }

  .lightbox__close:hover {
    background: rgba(242, 244, 238, 0.14);
  }

  /* --- The doctors (home teaser) --------------------------------------------- */
  .doctor-cards {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .doctor-card a {
    display: block;
    text-decoration: none;
  }

  .doctor-card img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: 50% 15%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .doctor-card__name {
    display: block;
    margin-top: var(--space-sm);
    font-family: var(--font-ui);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-ink);
  }

  /* --- Service cards -------------------------------------------------------- */
  .cards {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .card-item {
    display: flex;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    width: 100%;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-ink);
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .card:hover,
  .card:focus-visible {
    border-color: var(--color-green);
    box-shadow: var(--shadow);
    color: var(--color-ink);
  }

  .card__title {
    color: var(--color-green);
  }

  .card__body {
    max-width: none;
    color: var(--color-ink);
  }

  .card__more {
    margin-top: auto;
    padding-top: var(--space-2xs);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-green);
  }

  /* --- Reviews -------------------------------------------------------------- */
  .reviews {
    background: var(--color-paper);
    border-block: 1px solid var(--color-border);
  }

  .reviews__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .review {
    height: 100%;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .review__quote {
    max-width: none;
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--color-ink);
  }

  .review__cite {
    display: block;
    margin-top: var(--space-md);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    font-style: normal;
    color: var(--color-green);
  }

  /* --- Visit us ------------------------------------------------------------- */
  .visit {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .visit__sub {
    margin-bottom: var(--space-sm);
  }

  .visit__hours {
    list-style: none;
    padding: 0;
  }

  .visit__hours li {
    padding-block: var(--space-3xs);
    color: var(--color-ink);
  }

  .visit__address {
    font-style: normal;
    color: var(--color-ink);
    margin-bottom: var(--space-sm);
  }

  .visit__line {
    margin-bottom: var(--space-2xs);
  }

  .visit__line a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .visit__cta {
    margin-top: var(--space-sm);
  }

  /* --- Wider viewports (768px matches the shell nav + other pages) --------- */
  @media (min-width: 768px) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .reviews__list {
      grid-template-columns: repeat(3, 1fr);
    }

    .visit {
      grid-template-columns: 1fr 1fr;
    }

    .doctor-cards {
      grid-template-columns: repeat(3, 1fr);
    }

    .carousel__slides {
      aspect-ratio: 3 / 2;
    }
  }

  @media (min-width: 900px) {
    .hero__inner {
      /* The photo is the hero: it takes roughly two-thirds of the band. */
      grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    }

    .cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel__slide {
      transition: none;
    }
  }
</style>

<script>
  // Hero carousel: auto-advances quietly; the edges step, the middle opens the
  // photo large, arrow keys work, and touch swipes. Pauses on hover/focus and
  // when the tab is hidden; no autoplay for users who prefer reduced motion.
  const root = document.querySelector<HTMLElement>("[data-carousel]");
  const lightbox = document.querySelector<HTMLElement>("[data-lightbox]");
  const lightboxImg =
    lightbox?.querySelector<HTMLImageElement>("[data-lightbox-img]");

  if (root && lightbox && lightboxImg) {
    const slides = [...root.querySelectorAll<HTMLElement>("[data-slide]")];
    let index = 0;
    let timer: number | undefined;
    let lastFocus: HTMLElement | null = null;

    const show = (i: number) => {
      index = (i + slides.length) % slides.length;
      slides.forEach((s, n) => s.classList.toggle("is-active", n === index));
      if (!lightbox.hidden) syncLightbox();
    };

    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const stop = () => {
      if (timer !== undefined) {
        clearInterval(timer);
        timer = undefined;
      }
    };
    const start = () => {
      if (reducedMotion || timer !== undefined || !lightbox.hidden) return;
      timer = window.setInterval(() => show(index + 1), 5000);
    };

    // Lightbox
    const syncLightbox = () => {
      const img = slides[index].querySelector("img");
      if (img && lightboxImg) {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
      }
    };
    const openLightbox = () => {
      lastFocus = document.activeElement as HTMLElement | null;
      syncLightbox();
      lightbox.hidden = false;
      document.body.style.overflow = "hidden";
      stop();
      lightbox.querySelector<HTMLElement>("[data-close]")?.focus();
    };
    const closeLightbox = () => {
      lightbox.hidden = true;
      document.body.style.overflow = "";
      lastFocus?.focus();
    };

    root.querySelector("[data-prev]")?.addEventListener("click", () => {
      show(index - 1);
      stop();
    });
    root.querySelector("[data-next]")?.addEventListener("click", () => {
      show(index + 1);
      stop();
    });
    root.querySelector("[data-open]")?.addEventListener("click", openLightbox);

    lightbox.querySelector("[data-close]")?.addEventListener("click", closeLightbox);
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Keyboard: arrows work while the carousel has focus or the lightbox is open.
    document.addEventListener("keydown", (e) => {
      const carouselFocused = root.contains(document.activeElement);
      const lightboxOpen = !lightbox.hidden;
      if (!carouselFocused && !lightboxOpen) return;
      if (e.key === "ArrowLeft") {
        show(index - 1);
        stop();
      } else if (e.key === "ArrowRight") {
        show(index + 1);
        stop();
      } else if (e.key === "Escape" && lightboxOpen) {
        closeLightbox();
      }
    });

    // Touch: swipe to step (on the carousel and inside the lightbox).
    const addSwipe = (el: HTMLElement) => {
      let startX = 0;
      let startY = 0;
      el.addEventListener(
        "touchstart",
        (e) => {
          startX = e.touches[0].clientX;
          startY = e.touches[0].clientY;
        },
        { passive: true }
      );
      el.addEventListener(
        "touchend",
        (e) => {
          const dx = e.changedTouches[0].clientX - startX;
          const dy = e.changedTouches[0].clientY - startY;
          if (Math.abs(dx) > 44 && Math.abs(dx) > Math.abs(dy) * 1.5) {
            show(index + (dx < 0 ? 1 : -1));
            stop();
          }
        },
        { passive: true }
      );
    };
    addSwipe(root);
    addSwipe(lightbox);

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);
    document.addEventListener("visibilitychange", () =>
      document.hidden ? stop() : start()
    );

    start();
  }
</script>
