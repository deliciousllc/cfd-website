---
import BaseLayout from "../layouts/BaseLayout.astro";

// Base-aware URLs. On GitHub Pages everything sits under /cfd-website; only
// Astro frontmatter can read import.meta.env.BASE_URL.
const base = import.meta.env.BASE_URL;
const b = base.endsWith("/") ? base : base + "/";

const tel = "tel:360-568-6017";

// External apply links — verbatim from products.md (Financing section).
const careCreditUrl = "https://www.carecredit.com/go/442XZT/";
const cherryUrl = "https://tree.withcherry.com/centennial-family-dentistry";
const willoUrl = "https://partners.willo.com/CFDSNOHOMISH";

// -------------------------------------------------------------------------
// PRICING CONVENTION for the six services the source site contradicts itself
// on (products.md gotchas 2–7). products.md records BOTH verbatim figures for
// each; we never pick a winner. Presentation: show a RANGE that spans both
// listed figures, mark it with a footnote (†) that points to the "About these
// prices" note, and say the exact price is confirmed at the visit. Applied
// consistently to all six contested lines and nowhere else.
//   Periodic exam   $76  vs $85       -> $76–$85
//   Cleaning        $139 vs $145      -> $139–$145
//   Fillings        $212-416 vs $270-520 -> $212–$520
//   Crowns          $1,828 vs $1,980  -> $1,828–$1,980
//   Botox/unit      $13  vs $14       -> $13–$14 per unit
//   Invisalign      $3,000-5,400 vs $5,400 -> $3,000–$5,400
// Non-contested prices are shown verbatim as the single listed figure.
// Services with no listed price get NO price line (gotcha 10) — never
// "call for pricing".
// -------------------------------------------------------------------------

// Section order matches the LOCKED anchor IDs from service-inventory.md, which
// the Home page's cards link to. Do not rename or re-slug.
const groups = [
  {
    id: "routine-care",
    name: "Routine care",
    intro:
      "Come in every six months. Dr. Eve, Dr. Greene, or Dr. Gulrajani take X-rays and check the health of your teeth, gums, and jaw, then ask about your home-care habits to get the full picture. Your hygienist removes tartar, polishes with a fluoride paste, tests each tooth, and shows you how to keep decay and gum disease away at home.",
    services: [
      {
        name: "Cleanings and exams",
        prices: [
          { label: "New patient exam, cleaning, and imaging", price: "$456" },
          { label: "Comprehensive exam", price: "$139" },
          { label: "Periodic exam", price: "$76–$85", contested: true },
          { label: "Emergency exam", price: "$125" },
          { label: "Cleaning", price: "$139–$145", contested: true },
        ],
      },
    ],
  },
  {
    id: "restorative",
    name: "Restorative",
    intro:
      "When a tooth is sore or damaged, this is how we get it healthy again — fillings, crowns, and extractions.",
    services: [
      {
        name: "Fillings, crowns, and extractions",
        prices: [
          { label: "Fillings", price: "$212–$520", contested: true },
          { label: "Crowns", price: "$1,828–$1,980", contested: true },
          { label: "Extractions", price: "$285–$440" },
        ],
      },
    ],
  },
  {
    id: "cosmetic",
    name: "Cosmetic",
    intro:
      "Renewing your smile — whitening, Invisalign, veneers, and teeth-colored fillings (priced under Restorative above). We also offer Botox and fillers, and you don’t have to be a patient here to book them.",
    services: [
      {
        name: "Teeth whitening",
        body:
          "Whitening tailored to your goals, whether you want a dramatic lift in a single visit or a gradual change from home.",
        prices: [
          { label: "Zoom in-office whitening", price: "$600" },
          { label: "Opalescence take-home syringes", price: "$45 for 2-pack" },
          { label: "Custom trays", price: "$350" },
          { label: "Opalescence Go trays", price: "$90 for 10-pack" },
        ],
      },
      {
        name: "Invisalign",
        body:
          "Clear aligners for teens and adults instead of traditional braces. Invisalign patients are seen every six weeks for check-ins.",
        prices: [
          { label: "Invisalign", price: "$3,000–$5,400", contested: true },
        ],
      },
      {
        name: "Botox and fillers",
        body:
          "We offer both medical and cosmetic Botox — for smoothing fine lines or easing jaw tension. You do not have to be a dental patient to schedule these.",
        prices: [
          { label: "Botox", price: "$13–$14 per unit", contested: true },
          { label: "Filler", price: "$650 per syringe" },
        ],
      },
      {
        name: "Veneers",
        body:
          "Veneers are offered as part of cosmetic care. The practice doesn’t list a set price for them.",
      },
    ],
  },
  {
    id: "sleep-tmj",
    name: "Sleep & TMJ",
    intro:
      "Help for sleep apnea and for the jaw pain, clicking, and headaches of TMJ.",
    services: [
      {
        name: "Sleep apnea",
        body:
          "During every exam, our doctors look for signs of sleep apnea, like a small airway, and can set you up with an at-home sleep study — usually cheaper and more comfortable than an in-lab study. If an oral sleep appliance will help, we make it here. We work closely with medical professionals for an accurate diagnosis, and we’re a good option if you’re looking for an alternative to CPAP.",
        prices: [
          { label: "At-home sleep test", price: "$250" },
          { label: "Oral sleep device", price: "$2,500" },
        ],
      },
      {
        name: "TMJ",
        body:
          "Jaw soreness, clicking or popping, facial pain, or frequent headaches can be TMJ (also called TMD). We use 3D imaging to find the cause and fit a custom solution.",
        prices: [
          { label: "CBCT imaging", price: "$550" },
          { label: "Occlusal orthotic device", price: "$1,268" },
          {
            label: "Botox for muscle-related TMJ",
            price: "$13–$14 per unit",
            contested: true,
          },
        ],
      },
    ],
  },
  {
    id: "technology-extras",
    name: "Technology & extras",
    intro:
      "The tools and touches that make care faster and gentler.",
    services: [
      {
        name: "3D printing",
        body:
          "We fabricate custom night guards, onlays, and more in-house with 3D printing — faster turnaround, fewer appointments, and restorations tailored to your bite.",
      },
      {
        name: "Laser dentistry",
        body:
          "A gentle CO₂ laser for frenectomy procedures, for faster healing and less discomfort.",
        prices: [{ label: "Lingual frenectomy", price: "$572" }],
      },
      {
        name: "Willo toothbrush",
        body:
          "An automated brushing system that cleans all sides of your teeth at once — helpful if brushing technique or time is a struggle.",
        link: { url: willoUrl, label: "More information on Willo" },
      },
      {
        name: "Kids’ Days",
        body:
          "A few times each month we set aside days just for our younger patients, with playful themes and gentle, age-appropriate care. Ask about the next Kids’ Day when you schedule — they fill quickly.",
      },
    ],
  },
];

// Financing — folded onto this page as its own section (#financing). Facts
// verbatim from products.md.
const financingIntro =
  "We believe quality dental care should be accessible and affordable. We offer flexible financing through CareCredit and Cherry — two providers that let you split treatment costs into monthly payments. Both have a quick application, often with a decision in minutes, and our front-desk team is happy to walk you through it.";

const financingRows = [
  {
    feature: "Type of financing",
    careCredit: "Healthcare credit card",
    cherry: "“Buy Now, Pay Later” plan",
  },
  {
    feature: "Approval time",
    careCredit: "Instant approval in most cases",
    cherry: "Instant approval in most cases",
  },
  {
    feature: "Payment terms",
    careCredit: "Short and long term options (6–60 months)",
    cherry: "Flexible monthly payment plans (split up to 12 months)",
  },
  {
    feature: "Interest options",
    careCredit: "0% interest promotional periods available",
    cherry: "0% APR options available based on credit",
  },
  {
    feature: "Credit check",
    careCredit: "Yes",
    cherry: "Soft credit check (no impact on score)",
  },
  {
    feature: "Best for",
    careCredit: "Larger treatment plans or ongoing care",
    cherry: "Smaller procedures or one-time costs",
  },
];

// Jump links for the in-page section index.
const jumpLinks = groups
  .map((g) => ({ id: g.id, name: g.name }))
  .concat([{ id: "financing", name: "Financing" }]);
---

<BaseLayout
  title="Services & Pricing | Centennial Family Dentistry Snohomish"
  description="What dental care costs at Centennial Family Dentistry in Snohomish, WA — routine care, restorative, cosmetic, sleep & TMJ, technology, and financing, with prices listed."
>
  <section class="container page-head" aria-labelledby="page-title">
    <p class="eyebrow">Services &amp; pricing</p>
    <h1 id="page-title">Services &amp; Pricing</h1>
    <p class="lede">
      Here’s what things cost. The prices below are the practice’s own published
      rates, so you’ll know the number before you’re in the chair.
    </p>
    <div class="pricing-note" id="pricing-note">
      <p>
        <strong>About these prices.</strong> A few lines show a range and are
        marked with a <span aria-hidden="true">†</span>. The practice’s current
        pages list two figures for those services, so we show both here rather
        than choose one — your exact price is confirmed at your visit. For any
        treatment not listed, call the office at
        <a href={tel}>360-568-6017</a>.
      </p>
    </div>
    <nav class="jump" aria-label="Jump to a section">
      <ul role="list">
        {
          jumpLinks.map((l) => (
            <li>
              <a href={`#${l.id}`}>{l.name}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </section>

  {
    groups.map((group) => (
      <section
        class="container group"
        id={group.id}
        aria-labelledby={`${group.id}-title`}
      >
        <h2 id={`${group.id}-title`} class="group__title">
          {group.name}
        </h2>
        <p class="group__intro">{group.intro}</p>

        <div class="services">
          {group.services.map((service) => (
            <article class="service">
              <h3 class="service__name">{service.name}</h3>
              {service.body && <p class="service__body">{service.body}</p>}
              {service.prices && (
                <dl class="prices">
                  {service.prices.map((p) => (
                    <div class="price-row">
                      <dt class="price-row__label">
                        {p.label}
                        {p.contested && (
                          <a
                            class="fn"
                            href="#pricing-note"
                            aria-label="Range shows two listed figures — see About these prices"
                          >
                            †
                          </a>
                        )}
                      </dt>
                      <dd class="price-row__price">{p.price}</dd>
                    </div>
                  ))}
                </dl>
              )}
              {service.link && (
                <p class="service__link-out">
                  <a href={service.link.url} target="_blank" rel="noopener noreferrer">
                    {service.link.label}
                  </a>
                </p>
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  }

  <section class="container group" id="financing" aria-labelledby="financing-title">
    <h2 id="financing-title" class="group__title">Financing</h2>
    <p class="group__intro">{financingIntro}</p>

    <div class="table-wrap">
      <table class="finance-table">
        <caption class="sr-only">
          CareCredit and Cherry financing compared
        </caption>
        <thead>
          <tr>
            <th scope="col">Feature</th>
            <th scope="col">CareCredit</th>
            <th scope="col">Cherry</th>
          </tr>
        </thead>
        <tbody>
          {
            financingRows.map((row) => (
              <tr>
                <th scope="row">{row.feature}</th>
                <td>{row.careCredit}</td>
                <td>{row.cherry}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <ul class="apply-links" role="list">
      <li>
        <a href={careCreditUrl} target="_blank" rel="noopener noreferrer">
          Apply with CareCredit
        </a>
      </li>
      <li>
        <a href={cherryUrl} target="_blank" rel="noopener noreferrer">
          Apply with Cherry
        </a>
      </li>
    </ul>
  </section>

  <section class="container cta-band" aria-labelledby="cta-title">
    <h2 id="cta-title">Have a question about any of this?</h2>
    <p>Call the office and we’ll talk it through — no phone tree, just our front desk.</p>
    <a class="btn-call" href={tel}>Call 360-568-6017</a>
  </section>
</BaseLayout>

<style>
  /* --- Page head ------------------------------------------------------------ */
  .page-head {
    padding-block: var(--space-2xl) var(--space-lg);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-green);
    margin-bottom: var(--space-sm);
  }

  .lede {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-body);
    color: var(--color-ink);
    margin-top: var(--space-md);
  }

  .pricing-note {
    margin-top: var(--space-lg);
    padding: var(--space-md);
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .pricing-note p {
    max-width: var(--measure);
    font-size: var(--text-sm);
    color: var(--color-ink);
  }

  /* --- Jump links ----------------------------------------------------------- */
  .jump {
    margin-top: var(--space-lg);
  }

  .jump ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-md);
  }

  .jump a {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-green);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .jump a:hover {
    color: var(--color-green-deep);
  }

  /* --- Group sections ------------------------------------------------------- */
  .group {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-border);
    scroll-margin-top: var(--space-lg);
  }

  .group__title {
    color: var(--color-green);
  }

  .group__intro {
    margin-top: var(--space-sm);
    color: var(--color-ink);
  }

  /* --- Services within a group --------------------------------------------- */
  .services {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .service {
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .service__name {
    color: var(--color-ink);
  }

  .service__body {
    margin-top: var(--space-2xs);
    color: var(--color-ink);
  }

  .service__link-out {
    margin-top: var(--space-sm);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .service__link-out a {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  /* --- Price list (dt = line item, dd = amount; associated pair) ------------ */
  .prices {
    margin-top: var(--space-md);
  }

  .price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2xs) var(--space-sm);
    padding-block: var(--space-2xs);
    border-top: 1px solid var(--color-border);
  }

  .price-row:first-child {
    border-top: 0;
  }

  .price-row__label {
    font-family: var(--font-ui);
    color: var(--color-ink);
  }

  .price-row__price {
    font-family: var(--font-ui);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-ink);
    white-space: nowrap;
  }

  .fn {
    font-family: var(--font-ui);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-green);
    padding-inline: 0.15em;
  }

  .fn:hover {
    color: var(--color-green-deep);
  }

  /* --- Financing table ------------------------------------------------------ */
  .table-wrap {
    margin-top: var(--space-lg);
    overflow-x: auto;
  }

  .finance-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 34rem;
  }

  .finance-table caption {
    text-align: left;
  }

  .finance-table th,
  .finance-table td {
    padding: var(--space-sm);
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
  }

  .finance-table thead th {
    font-size: var(--text-base);
    color: var(--color-ink);
    border-bottom: 2px solid var(--color-green);
  }

  .finance-table tbody th {
    color: var(--color-ink);
    font-weight: 600;
    background: var(--color-paper);
  }

  .finance-table td {
    color: var(--color-ink);
  }

  .apply-links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .apply-links a {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  /* --- Closing CTA band ----------------------------------------------------- */
  .cta-band {
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .cta-band p {
    max-width: var(--measure);
    margin: var(--space-sm) auto var(--space-lg);
    color: var(--color-ink);
  }

  /* --- Screen-reader-only utility ------------------------------------------- */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* --- Wider viewports (breakpoint 768, matching the shell) ----------------- */
  @media (min-width: 768px) {
    .services {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
